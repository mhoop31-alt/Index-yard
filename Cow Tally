<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { background: #000; color: #fff; font-family: sans-serif; text-align: center; }
        .total-box { border: 5px solid #00ffcc; margin: 10px; padding: 20px; border-radius: 10px; }
        .field-box { background: #222; margin: 10px; padding: 15px; border-radius: 10px; border: 1px solid #444; }
        .big-num { font-size: 60px; font-weight: bold; margin: 10px; display: block; }
        .btn-add { background: #28a745; color: #fff; width: 100%; font-size: 30px; padding: 30px; border: none; border-radius: 10px; font-weight: bold; }
        .btn-small { background: #555; color: #fff; width: 45%; padding: 15px; border: none; border-radius: 5px; margin-top: 10px; }
        h1 { margin: 5px; color: #00ffcc; font-size: 18px; }
    </style>
</head>
<body>

    <div class="total-box">
        <h1>GRAND TOTAL</h1>
        <div id="grandTotal" class="big-num">0</div>
    </div>

    <div class="field-box">
        <input type="text" value="Field 1" style="background:none; color:#ffcc00; border:none; text-align:center; font-size:20px;">
        <div id="num1" class="big-num">0</div>
        <button class="btn-add" onclick="addOne(1)">+ ADD</button>
        <button class="btn-small" onclick="subOne(1)">- 1</button>
        <button class="btn-small" onclick="resetOne(1)">CLR</button>
    </div>

    <div class="field-box">
        <input type="text" value="Field 2" style="background:none; color:#ffcc00; border:none; text-align:center; font-size:20px;">
        <div id="num2" class="big-num">0</div>
        <button class="btn-add" onclick="addOne(2)">+ ADD</button>
        <button class="btn-small" onclick="subOne(2)">- 1</button>
        <button class="btn-small" onclick="resetOne(2)">CLR</button>
    </div>

<script>
    // The most basic way to store numbers
    var count1 = 0;
    var count2 = 0;

    function refresh() {
        // Force the numbers onto the screen
        document.getElementById('num1').innerHTML = count1;
        document.getElementById('num2').innerHTML = count2;
        document.getElementById('grandTotal').innerHTML = (count1 + count2);
    }

    function addOne(id) {
        if(id == 1) { count1 = count1 + 1; }
        if(id == 2) { count2 = count2 + 1; }
        refresh();
    }

    function subOne(id) {
        if(id == 1 && count1 > 0) { count1 = count1 - 1; }
        if(id == 2 && count2 > 0) { count2 = count2 - 1; }
        refresh();
    }

    function resetOne(id) {
        if(confirm("Clear?")) {
            if(id == 1) { count1 = 0; }
            if(id == 2) { count2 = 0; }
            refresh();
        }
    }
</script>
</body>
</html>
